# 🗂️ Command Dispatcher Registry Router

Notes:
* Avoids the infinite `switch-case` antipattern.
* Adding a new mail type requires zero modifications to the Worker engine.

[js] Abstract Interface Model:
File Location: `src/modules/email/handlers/base.handler.ts`
```typescript
import { Job } from "bullmq";

export interface IEmailJobHandler {
  execute(job: Job): Promise<void>;
}
```

[js] Concrete Domain Logic Handler:
File Location: `src/modules/email/handlers/welcome.handler.ts`
```typescript
import { Job } from "bullmq";
import { IEmailJobHandler } from "./base.handler.js";
import { nodemailerService } from "../services/nodemailer.service.js";
import { emailTemplates } from "../templates/email.template.js";

export class WelcomeHandler implements IEmailJobHandler {
  async execute(job: Job): Promise<void> {
    const { email, name } = job.data;
    console.log(`[WelcomeHandler] Dispatch execution path for: ${email}`);

    const htmlContent = emailTemplates.getWelcomeHTML(name);
    
    await nodemailerService.send({
      to: email,
      subject: "Welcome to the Community! 🎉",
      html: htmlContent
    });
  }
}
```

[js] Registry Central Router Module:
File Location: `src/modules/email/registry.ts`
```typescript
import { EMAIL_JOBS, EmailJobType } from "./constants/job.constant.js";
import { IEmailJobHandler } from "./handlers/base.handler.js";
import { WelcomeHandler } from "./handlers/welcome.handler.js";

const registry: Record<EmailJobType, IEmailJobHandler> = {
  [EMAIL_JOBS.SEND_WELCOME]: new WelcomeHandler(),
};

export const getEmailHandler = (jobName: string): IEmailJobHandler | null => {
  return registry[jobName as EmailJobType] || null;
};
```

