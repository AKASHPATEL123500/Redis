[js] Redis Server Config:
File Location: `src/config/redis.ts`
```typescript
import Redis from "ioredis";

const REDIS_URL = process.env.REDIS_URL || "redis://127.0.0.1:6379";

// Shared connection string for application cache tier
const redis = new Redis(REDIS_URL, { maxRetriesPerRequest: null });

// Schema model structure required strictly by BullMQ
const redisConnectionConfig = {
  host: process.env.REDIS_HOST || "127.0.0.1",
  port: Number(process.env.REDIS_PORT) || 6379,
  maxRetriesPerRequest: null,
};

export { redis as default, redisConnectionConfig };
```

