# 👮 The Background Traffic Police Worker

TODO:
[√] Inject registry router parsing into worker lifecycle loop
[ ] Define environmental concurrency limit boundaries

[js] Worker Processing Pipeline:
File Location: `src/modules/email/worker/email.worker.ts`
```typescript
import { Worker, Job } from "bullmq";
import { redisConnectionConfig } from "../../../config/redis.js";
import { getEmailHandler } from "../registry.js";

export const emailWorker = new Worker(
  "email-core-queue", 
  async (job: Job) => {
    console.log(`[Email Worker] Intercepted payload identifier: ${job.name}`);

    // Fetch the correct executable block from dictionary
    const handler = getEmailHandler(job.name);

    // Explicitly crash the worker thread if string mismatch occurs (Ensures Red State visibility in UI)
    if (!handler) {
      throw new Error(`[Email Worker Critical] Missing concrete implementation instance for: ${job.name}`);
    }

    // Execute business domain task safely
    await handler.execute(job);
  },
  {
    connection: redisConnectionConfig,
    concurrency: Number(process.env.WORKER_CONCURRENCY) || 3, // Safe multi-processing execution parallel streams
  }
);
```

