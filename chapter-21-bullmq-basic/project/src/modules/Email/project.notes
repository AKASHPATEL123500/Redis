# 🏭 Isolated Feature Module: Email Domain Subsystem

Notes: Single domain model inside `src/modules/email/` boundary. No leaks to other parts.

[js] Strict Constants Mapping:
File Location: `src/modules/email/constants/job.constant.ts`
```typescript
export const EMAIL_JOBS = {
  SEND_WELCOME: "EMAIL__SEND_WELCOME",
  SEND_OTP: "EMAIL__SEND_OTP",
} as const;

export type EmailJobType = typeof EMAIL_JOBS[keyof typeof EMAIL_JOBS];
```

[js] Unified Mail Delivery Transport:
File Location: `src/modules/email/services/nodemailer.service.ts`
```typescript
import nodemailer from "nodemailer";

// Permanent persistent single transport channel stream
const transporter = nodemailer.createTransport({
  service: "gmail",
  auth: {
    user: process.env.MAIL_USER,
    pass: process.env.MAIL_PASS,
  },
});

export const nodemailerService = {
  async send({ to, subject, html }: { to: string; subject: string; html: string }): Promise<void> {
    const info = await transporter.sendMail({
      from: `ARG COMMUNITY <${process.env.MAIL_USER}>`,
      to,
      subject,
      html,
    });
    console.log(`[Nodemailer Dispatched] Message Token ID: ${info.messageId}`);
  }
};
```

